# ============================================
# IAM MODULE CONFIGURATION
# ============================================
# ⚠️ THIS FILE IS FOR LOCAL DEVELOPMENT ONLY
# PRODUCTION: Secrets MUST be mounted via Docker Secrets (/run/secrets/*)
#             Non-secret config via ConfigMap volumes (/app/config/)
# ============================================

# Environment (dev, staging, production)
ENVIRONMENT=dev
APP_VERSION=0.1.0

# ============================================
# JWT CONFIGURATION (Security Critical)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change_me_in_production_use_32_char_random_string
JWT_REFRESH_SECRET=change_me_in_production_use_different_32_char_key
JWT_KEY_ID=kid_v1
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ============================================
# DATABASE - Dual Schema (ISO 8.27 Isolation)
# ============================================
# Profile Schema (less sensitive: emails, display names)
PROFILE_DATABASE_URL=postgresql://profile_user:profile_pass@localhost:5432/profile_db
PROFILE_POOL_MIN=5
PROFILE_POOL_MAX=20

# Auth Schema (HIGHLY SENSITIVE: password hashes, MFA secrets)
AUTH_DATABASE_URL=postgresql://auth_user:auth_pass@localhost:5432/auth_db
AUTH_POOL_MIN=5
AUTH_POOL_MAX=20

# ============================================
# REDIS (Session Storage - Optional for MVP)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=604800

# ============================================
# LOGGING (Structured logs for audit)
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# RATE LIMITING (Prevent brute-force)
# ============================================
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_REVOKE=10/minute

# ============================================
# FEATURE FLAGS
# ============================================
MFA_ENABLED=false
ARGO2ID_ENABLED=true

# ============================================
# CORS (Production: replace * with actual domains)
# ============================================
CORS_ORIGINS=*

# ============================================
# PRODUCTION ONLY - Docker Secrets Mapping
# ============================================
# For production, set ENVIRONMENT=production and mount secrets to:
#   /run/secrets/jwt_secret
#   /run/secrets/jwt_refresh_secret
#   
# Database passwords should be in the DATABASE_URL or separate secrets.
# See README.md for detailed production deployment guide.
